# SatoshiYield Frontend - environment variables
# Copy this to .env.local for local dev, or set these in your hosting provider.

# Network: "testnet" (default) or "mainnet"
VITE_NETWORK=testnet

# Deployer STX addresses (override only if you redeploy contracts under a
# different deployer wallet)
VITE_DEPLOYER_TESTNET=ST1JXS4BTWDNNEX28QS8ABHQSCAD4BQMAN11TP6B1
# VITE_DEPLOYER_MAINNET=SP...

# Vault contract name (default "vault-v2")
VITE_VAULT_CONTRACT_NAME=vault-v2

# Public URL of the yield indexer. Leave empty for local dev (vite proxies
# /api to http://localhost:3001). Set to the absolute indexer origin in prod.
# Example: https://satoshi-yield-indexer.onrender.com
VITE_INDEXER_URL=
