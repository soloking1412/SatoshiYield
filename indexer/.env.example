# SatoshiYield Indexer - environment variables

# HTTP port (Railway/Render/Fly all inject PORT automatically)
PORT=3001

# Stacks API base URL (testnet default). Use https://api.hiro.so for mainnet.
STACKS_API_URL=https://api.testnet.hiro.so

# Deployer STX address (the account that published the adapter contracts)
DEPLOYER_ADDRESS=ST1JXS4BTWDNNEX28QS8ABHQSCAD4BQMAN11TP6B1

# Cache TTL for the aggregated yield response (seconds)
CACHE_TTL_SECONDS=300

# Comma-separated list of allowed browser origins for CORS.
# Required in production — without it, defaults to localhost only.
# Example: https://satoshi-yield.vercel.app,https://satoshi-yield-beta.vercel.app
CORS_ALLOWED_ORIGINS=

# Hex private key (64 chars) of the oracle signer wallet.
# If set, the indexer pushes live APY from native protocol APIs to chain every 2 h.
# Must match one of the oracle slots registered on each adapter via set-oracle-at(idx, principal).
ORACLE_PRIVATE_KEY=

# Target network for oracle transactions: "testnet" or "mainnet"
STACKS_NETWORK=testnet
